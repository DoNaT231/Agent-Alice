# Server-side only — never prefix with VITE_ or NEXT_PUBLIC_
# Keys from AI Studio may start with AIza (standard) or AQ. (auth) — both are valid.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the default Gemini model
# GEMINI_MODEL=gemini-2.0-flash-001

# Dev only: set to true if antivirus/VPN causes SSL certificate errors locally
# GEMINI_INSECURE_TLS=true

# Firebase frontend config (safe to expose in the client)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
